# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/healthcare

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_MINIMUM_32_CHARS_RANDOM_STRING_HERE
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=local
DEBUG=True

# ── CORS (comma-separated URLs, or leave empty to allow all in local env) ─────
# BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_HOST=http://localhost:5173

# ── First superuser (ADMIN seed) ──────────────────────────────────────────────
FIRST_SUPERUSER=admin@healthcare
FIRST_SUPERUSER_PASSWORD=1234

# ── Email / SMTP (bỏ comment và điền thông tin nếu muốn gửi email thật) ───────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAILS_FROM_EMAIL=your_email@gmail.com
EMAILS_FROM_NAME=Healthcare Management System
SMTP_TLS=True

# ── VietQR Settings ───────────────────────────────────────────────────────────
VIETQR_BANK_ID=HDB
VIETQR_ACCOUNT_NO=123456789
VIETQR_ACCOUNT_NAME=Your Name
VIETQR_CLIENT_ID=
VIETQR_API_KEY=
VIETQR_HOST=https://api.vietqr.org
VIETQR_USERNAME=
VIETQR_SECRET_KEY=
